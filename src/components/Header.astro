---
/**
 * SITE HEADER COMPONENT
 * Renders the primary navigation bar.
 * Elements:
 * - Brand/Name link with professional typography.
 * - Desktop/Mobile navigation links using HeaderLink.astro.
 * - Integrated ThemeToggle for Dark/Light mode switching.
 */
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.jsx";
import CommandPalette from "./CommandPalette.jsx";
import data from "../data/portfolio.json";
import details from "../data/details.json";

// Check if we're on the homepage
const isHomepage = Astro.url.pathname === "/";
---

<header
  class="fixed top-0 inset-x-0 z-50 w-full transition-colors duration-300"
>
  <CommandPalette client:only="react" data={data} />
  <!-- Bar Background & Blur -->
  <div
    class="absolute inset-0 backdrop-blur-md bg-white/70 dark:bg-darkBg/70 border-b border-slate-200 dark:border-slate-800 -z-10"
  >
  </div>

  <nav class="max-w-6xl mx-auto px-4 py-4 relative z-50">
    <div class="flex items-center justify-between relative z-[60]">
      <!-- LOGO -->
      <a
        href="/"
        class="text-xl font-bold text-slate-900 dark:text-white hover:text-primary transition-colors"
      >
        {data.basics.name}
      </a>

      <!-- MOBILE CONTROLS -->
      <div class="flex items-center gap-2 md:hidden">
        <!-- THEME TOGGLE (Mobile) -->
        <ThemeToggle client:load />

        <!-- HAMBURGER BUTTON -->
        <button
          id="mobile-menu-toggle"
          class="p-2 text-slate-600 dark:text-slate-300 hover:text-primary transition-colors focus:outline-none"
          aria-label="Toggle Menu"
        >
          <svg
            id="hamburger-icon"
            class="w-6 h-6 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            id="close-icon"
            class="hidden w-6 h-6 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- DESKTOP NAV -->
      <div class="hidden md:flex items-center gap-6">
        <HeaderLink href="/">{details.uiConfig.nav.home}</HeaderLink>
        {
          isHomepage && (
            <>
              <HeaderLink href="#skills">{details.uiConfig.sections.skills.navLabel}</HeaderLink>
              <HeaderLink href="#experience">{details.uiConfig.sections.experience.navLabel || details.uiConfig.sections.experience.title}</HeaderLink>
              {data.certs && data.certs.length > 0 && (
                <HeaderLink href="#certifications">{details.uiConfig.sections.certifications.navLabel}</HeaderLink>
              )}
            </>
          )
        }
        <HeaderLink href="/projects">{details.uiConfig.nav.projects}</HeaderLink>
        <HeaderLink href="/blog">{details.uiConfig.nav.blog}</HeaderLink>

        <!-- SEPARATOR -->
        <div
          class="hidden md:block w-px h-6 bg-slate-200 dark:bg-slate-800 ml-2"
        >
        </div>

        <!-- THEME TOGGLE (Desktop) -->
        <div class="hidden md:block">
          <ThemeToggle client:load />
        </div>
      </div>
    </div>
  </nav>

  <!-- MOBILE OVERLAY MENU -->
  <div
    id="mobile-menu-overlay"
    class="fixed top-0 left-0 w-full h-[100dvh] bg-white dark:bg-[#030712] z-[55] translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col pt-24"
  >
    <div class="px-6 py-8 flex flex-col gap-10 overflow-y-auto h-full">
      {/* Top Header Helper */}
      <div class="flex items-center justify-between px-2 mb-2">
        <span
          class="text-[10px] font-black uppercase shadow-sm tracking-[0.2em] text-primary/60"
          >Navigation</span
        >
        <button
          id="mobile-menu-close-text"
          class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 active:text-primary"
        >
          [ Close Menu ]
        </button>
      </div>

      <div class="flex flex-col gap-2">
        <a
          href="/"
          class="px-4 py-6 text-4xl font-black text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 flex items-center justify-between group active:bg-slate-50 dark:active:bg-slate-900 rounded-2xl transition-colors"
        >
          {details.uiConfig.nav.home} <span class="text-primary opacity-20 transition-opacity">→</span>
        </a>
        <a
          href="/projects"
          class="px-4 py-6 text-4xl font-black text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 flex items-center justify-between group active:bg-slate-50 dark:active:bg-slate-900 rounded-2xl transition-colors"
        >
          {details.uiConfig.nav.projects} <span class="text-primary opacity-20 transition-opacity"
            >→</span
          >
        </a>
        <a
          href="/blog"
          class="px-4 py-6 text-4xl font-black text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 flex items-center justify-between group active:bg-slate-50 dark:active:bg-slate-900 rounded-2xl transition-colors"
        >
          {details.uiConfig.nav.blog} <span class="text-primary opacity-20 transition-opacity">→</span>
        </a>
      </div>

      {
        isHomepage && (
          <div class="flex flex-col gap-6">
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/60 px-2">
              Section Jumps
            </span>
            <div class="grid grid-cols-1 gap-3 px-2">
              <a
                href="#skills"
                class="flex items-center gap-4 p-5 bg-slate-50 dark:bg-slate-900/50 rounded-2xl text-lg font-bold text-slate-700 dark:text-slate-300 border border-slate-100 dark:border-slate-800 active:border-primary transition-all"
              >
                <span class="w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 rounded-xl shadow-sm">
                  {details.uiConfig.sections.skills.emoji}
                </span>
                {details.uiConfig.sections.skills.navLabel}
              </a>
              <a
                href="#experience"
                class="flex items-center gap-4 p-5 bg-slate-50 dark:bg-slate-900/50 rounded-2xl text-lg font-bold text-slate-700 dark:text-slate-300 border border-slate-100 dark:border-slate-800 active:border-primary transition-all"
              >
                <span class="w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 rounded-xl shadow-sm">
                  {details.uiConfig.sections.experience.emoji}
                </span>
                {details.uiConfig.sections.experience.navLabel || details.uiConfig.sections.experience.title}
              </a>
              {data.certs && data.certs.length > 0 && (
                <a
                  href="#certifications"
                  class="flex items-center gap-4 p-5 bg-slate-50 dark:bg-slate-900/50 rounded-2xl text-lg font-bold text-slate-700 dark:text-slate-300 border border-slate-100 dark:border-slate-800 active:border-primary transition-all"
                >
                  <span class="w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 rounded-xl shadow-sm">
                    {details.uiConfig.sections.certifications.emoji}
                  </span>
                  {details.uiConfig.sections.certifications.navLabel}
                </a>
              )}
            </div>
          </div>
        )
      }

      <!-- Bottom Branding -->
      <div
        class="mt-auto pt-10 pb-6 text-center border-t border-slate-100 dark:border-slate-900 opacity-60"
      >
        <p
          class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400"
        >
          {data.basics.name} Portfolio
        </p>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  function initMobileMenu() {
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const overlay = document.getElementById("mobile-menu-overlay");
    const closeTextBtn = document.getElementById("mobile-menu-close-text");

    if (!toggleBtn || !overlay) return;

    // Helper to get icons from the actual button in DOM
    const getIcons = (btn) => ({
      hamburger: btn.querySelector("#hamburger-icon"),
      close: btn.querySelector("#close-icon"),
    });

    // Cleanup existing listeners if any by cloning
    const newToggle = toggleBtn.cloneNode(true);
    toggleBtn.parentNode.replaceChild(newToggle, toggleBtn);

    const icons = getIcons(newToggle);
    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      if (isOpen) {
        overlay.classList.remove("translate-x-full");
        icons.hamburger?.classList.add("hidden");
        icons.close?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      } else {
        overlay.classList.add("translate-x-full");
        icons.hamburger?.classList.remove("hidden");
        icons.close?.classList.add("hidden");
        document.body.style.overflow = "";
      }
    }

    newToggle.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggleMenu();
    });

    closeTextBtn?.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });

    // Handle Link Clicks
    const links = overlay.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (isOpen) toggleMenu();
      });
    });

    // Close on resize
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768 && isOpen) {
        toggleMenu();
      }
    });
  }

  // Register for all lifecycle events
  document.addEventListener("DOMContentLoaded", initMobileMenu);
  document.addEventListener("astro:after-swap", initMobileMenu);
  // Backup immediate run
  initMobileMenu();
</script>
