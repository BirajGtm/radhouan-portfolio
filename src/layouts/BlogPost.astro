---
/**
 * BLOG POST LAYOUT
 * The standard template for technical articles and blog entries.
 * Includes: Breadcrumb navigation, Schema.org Article markup, and automatic Social Share buttons.
 */
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";
import Breadcrumb from "../components/Breadcrumb.astro";
import details from "../data/portfolio.json";

type Props = CollectionEntry<"blog">["data"] & {
  category?: string;
  slug?: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, slug } =
  Astro.props;

// Build breadcrumb items
const breadcrumbItems: { label: string; href?: string }[] = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
];

if (category) {
  const categoryName = category
    .split("-")
    .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
  breadcrumbItems.push({ label: categoryName, href: `/blog/${category}` });
}

breadcrumbItems.push({ label: title });
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        image: heroImage,
        datePublished: pubDate,
        dateModified: updatedDate || pubDate,
        author: {
          "@type": "Person",
          name: details.basics.name,
        },
      })}
    />
  </head>

  <body
    class="bg-white dark:bg-darkBg text-slate-900 dark:text-slate-200 font-sans transition-colors duration-300 flex flex-col min-h-screen"
  >
    <Header />
    <main class="flex-grow">
      <article class="max-w-5xl mx-auto px-4 py-12">
        <Breadcrumb items={breadcrumbItems} />
        {/* Hero Section */}
        <div class="mb-12 text-center">
          <div
            class="flex items-center justify-center gap-2 mb-6 text-sm text-slate-500 dark:text-slate-400"
          >
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <span class="italic">
                  (Updated: <FormattedDate date={updatedDate} />)
                </span>
              )
            }
          </div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-6 max-w-4xl mx-auto leading-tight"
          >
            {title}
          </h1>
          <p
            class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed"
          >
            {description}
          </p>
        </div>

        {/* Hero Image */}
        <div class="mb-16 rounded-2xl overflow-hidden shadow-2xl">
          {
            heroImage && (
              <Image
                width={1200}
                height={600}
                src={heroImage}
                alt=""
                class="w-full h-auto object-cover"
              />
            )
          }
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          {/* Sidebar (Share Buttons) */}
          <aside class="hidden lg:block lg:col-span-2">
            <div class="sticky top-24 space-y-4">
              <p
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4"
              >
                Share
              </p>
              <button
                class="w-full p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-blue-50 hover:text-blue-600 dark:hover:bg-blue-900/30 dark:hover:text-blue-400 transition-colors flex items-center justify-center gap-2"
                data-platform="twitter"
                aria-label="Share on Twitter"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
                  ></path></svg
                >
              </button>
              <button
                class="w-full p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-blue-50 hover:text-blue-600 dark:hover:bg-blue-900/30 dark:hover:text-blue-400 transition-colors flex items-center justify-center gap-2"
                data-platform="linkedin"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                  ></path></svg
                >
              </button>
            </div>
          </aside>

          {/* Main Content */}
          <div class="col-span-1 lg:col-span-8">
            <div
              class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-primary hover:prose-a:text-blue-600 prose-img:rounded-xl prose-img:shadow-lg"
            >
              <slot />
            </div>

            {/* Mobile Share Buttons (Bottom) */}
            <div
              class="lg:hidden mt-12 pt-8 border-t border-slate-200 dark:border-slate-800"
            >
              <p
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4 text-center"
              >
                Share this article
              </p>
              <div class="flex justify-center gap-4">
                <button
                  class="p-3 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-blue-50 hover:text-blue-600 transition-colors"
                  data-platform="twitter"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                    ><path
                      d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
                    ></path></svg
                  >
                </button>
                <button
                  class="p-3 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-blue-50 hover:text-blue-600 transition-colors"
                  data-platform="linkedin"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                    ><path
                      d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                    ></path></svg
                  >
                </button>
              </div>
            </div>

            {/* Comments Section */}
            <div
              class="mt-16 pt-12 border-t border-slate-200 dark:border-slate-800"
            >
              <h3
                class="text-2xl font-bold text-slate-900 dark:text-white mb-8"
              >
                Comments
              </h3>
              <div class="commentbox"></div>
              <script
                src="https://unpkg.com/commentbox.io/dist/commentBox.min.js"
              ></script>
              <script is:inline>
                commentBox("5701842210127872-proj");
              </script>
            </div>
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
