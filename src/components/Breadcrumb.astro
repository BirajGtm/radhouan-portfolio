---
/**
 * BREADCRUMB NAVIGATION
 * Generates an accessible navigation trail (e.g., Home > Blog > Article).
 * Helps users maintain spatial awareness and quickly jump back to previous directories.
 */
interface BreadcrumbItem {
  label: string;
  href?: string | undefined;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol
    class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400"
  >
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a href={item.href} class="hover:text-primary transition-colors">
              {item.label}
            </a>
          ) : (
            <span class="text-slate-900 dark:text-white font-medium">
              {item.label}
            </span>
          )}
          {index < items.length - 1 && (
            <svg
              class="w-4 h-4 text-slate-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          )}
        </li>
      ))
    }
  </ol>
</nav>
