---
/**
 * SITE FOOTER COMPONENT
 * Displays copyright info and social media profiles.
 * Dynamic: Automatically updates the current year.
 * Style: Uses a clean, centered layout with consistent icon spacing.
 */
import data from '../data/portfolio.json';
import details from '../data/details.json';
const today = new Date();
---

<footer class="relative mt-8">
	<!-- Gradient Top Border -->
	<div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
	
	<div class="bg-slate-50/80 dark:bg-[#030712]/80 backdrop-blur-xl transition-colors duration-300">
		<div class="max-w-5xl mx-auto px-4 py-16 flex flex-col items-center gap-10">
			
			<!-- IT "System Status" Command Line Vibe -->
			<div class="inline-flex items-center gap-3 px-6 py-2.5 rounded-full bg-white dark:bg-black/50 border border-slate-200 dark:border-slate-800 shadow-[0_0_15px_rgba(6,182,212,0.1)] hover:shadow-[0_0_20px_rgba(6,182,212,0.3)] transition-all duration-300">
				<span class="relative flex h-2.5 w-2.5">
				  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
				  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyan-500"></span>
				</span>
				<span class="text-[10px] sm:text-xs font-mono tracking-widest uppercase text-cyan-600 dark:text-cyan-400 font-bold">{details.uiConfig.footer.statusText}</span>
			</div>

			<!-- SOCIAL LINKS -->
			<div class="flex flex-wrap justify-center gap-6 sm:gap-10">
				{data.socials.map((social) => (
					<a 
						href={social.url} 
						target="_blank" 
						class="text-slate-500 hover:text-cyan-500 dark:hover:text-cyan-400 transition-all duration-300 hover:scale-110 hover:-translate-y-1 relative group"
						aria-label={`Follow on ${social.network}`}
					>
						<span class="sr-only">{social.network}</span>
						<span class="font-black text-xs tracking-widest uppercase relative z-10">{social.network}</span>
						<div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-cyan-400 group-hover:w-full transition-all duration-300"></div>
					</a>
				))}
			</div>

			<!-- COPYRIGHT -->
			<p class="text-slate-400 dark:text-slate-500 text-[10px] sm:text-xs font-mono font-medium opacity-60 text-center uppercase tracking-widest mt-4">
				&copy; {today.getFullYear()} {data.basics.name} <span class="mx-3 opacity-30">|</span> {details.uiConfig.footer.rightsText}
			</p>
		</div>
	</div>
</footer>