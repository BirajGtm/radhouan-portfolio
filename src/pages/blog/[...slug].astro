---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);

// Extract category from post.id (e.g., "information-tech/post-name.md" -> "information-tech")
const cleanId = post.id.replace(/\.md$/, "");
const slugParts = cleanId.split("/");
const category = slugParts.length > 1 ? slugParts[0] : undefined;
---

<BlogPost
  {...post.data}
  category={category}
  slug={post.id.replace(/\.md$/, "")}
>
  <Content />
</BlogPost>
